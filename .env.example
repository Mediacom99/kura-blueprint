# ─────────────────────────────────────────────────────────────
# Kura — environment template
# Copy to `.env` and fill in. NEVER commit `.env`. Secrets live here,
# never in the workspace Markdown files. See SECURITY.md.
# ─────────────────────────────────────────────────────────────

# ── Claude / Anthropic (the model behind Kura) ──────────────────
ANTHROPIC_API_KEY=
# Default model for everyday work; Opus is used for complex tasks.
KURA_DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# ── Telegram (primary channel) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Numeric IDs — see TOOLS.md. Get them from @userinfobot / the Bot API.
TELEGRAM_USER_ID=          # your direct chat id
TELEGRAM_GROUP_ID=         # optional "Kura HQ" group for reports

# ── Notion (structured storage) ─────────────────────────────────
NOTION_API_KEY=
# Database IDs go in TOOLS.md (they're identifiers, not secrets), but
# you can keep them here too if you prefer env-only config.

# ── OpenAI (Whisper STT + embeddings fallback) ──────────────────
OPENAI_API_KEY=

# ── GitHub (hourly workspace backup) ────────────────────────────
# Prefer the `gh` CLI credential helper over a raw token in the env.
GH_TOKEN=
GH_CONFIG_DIR=             # e.g. $HOME/.config/gh

# ── Weather (Open-Meteo — no key needed) ────────────────────────
KURA_LAT=                  # e.g. 38.7223
KURA_LON=                  # e.g. -9.1393
KURA_TZ=Europe/Lisbon

# ── Optional integrations ───────────────────────────────────────
# Google (Gmail + Calendar) via a `gog`-style CLI:
GOOGLE_ACCOUNT=            # e.g. you@gmail.com
# Premium TTS (e.g. ElevenLabs):
ELEVENLABS_API_KEY=
# Web search (e.g. Brave):
BRAVE_API_KEY=

# ── Dashboard (optional) ────────────────────────────────────────
DASHBOARD_PORT=3333
